#!/bin/bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
COMMITLINT_BIN="$REPO_ROOT/node_modules/.bin/commitlint"

if ! command -v node >/dev/null 2>&1; then
  echo "Node.js is required for commit message validation. Install Node.js and run 'npm install' in the repository root." >&2
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "npm is required for commit message validation. Install Node.js and run 'npm install' in the repository root." >&2
  exit 1
fi

if [ ! -x "$COMMITLINT_BIN" ]; then
  echo "Local commitlint dependencies are missing. Run 'npm install' in the repository root before committing." >&2
  exit 1
fi

"$COMMITLINT_BIN" --edit "$1"
