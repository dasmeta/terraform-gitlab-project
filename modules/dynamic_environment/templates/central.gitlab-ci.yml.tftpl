stages:
  - deploy
  - e2e-test
  - remove

variables:
  AWS_REGION: ${aws_region}
  CLUSTER_NAME: ${cluster_name}
  SECRET_ENV: ${secret_env}
  DYNAMIC_NAMESPACE: ${namespace_prefix}$CI_PIPELINE_ID
  DYNAMIC_BASE_DOMAIN: ${dynamic_base_domain}
  DYNAMIC_ENV_RELEASE: ${dynamic_env_release}
  GITLAB_AGENT_PATH: ${gitlab_agent_path}
  NAMESPACE_PREFIX: ${namespace_prefix}
  HELM_REPO_NAME: ${helm_repo_name}
  HELM_REPO_URL: ${helm_repo_url}
  WORK_DIR: ${work_dir}
  GITLAB_API_URL: ${gitlab_api_url}
  GITLAB_CLONE_BASE_URL: ${gitlab_clone_base_url}

.deploy-dynamic:
  stage: deploy
  image:
    name: alpine/k8s:1.20.15
    entrypoint: ["/bin/sh", "-c"]
  tags:
%{ for tag in runner_tags ~}
    - ${tag}
%{ endfor ~}
  environment:
    name: review/$DYNAMIC_NAMESPACE
    url: https://$DYNAMIC_NAMESPACE.$DYNAMIC_BASE_DOMAIN
    on_stop: remove-dynamic-stack
    kubernetes:
      agent: $GITLAB_AGENT_PATH
      dashboard:
        namespace: $DYNAMIC_NAMESPACE
  before_script:
    - apk add --no-cache python3 py3-pip git bash
    - pip3 install --no-cache-dir pyyaml
%{ if deploy_mode == "gitlab_agent" ~}
    - kubectl config use-context "$GITLAB_AGENT_PATH"
%{ else ~}
    - export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_DEV_ID
    - export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_DEV_KEY
    - aws --region $AWS_REGION eks update-kubeconfig --name $CLUSTER_NAME
%{ endif ~}
  script:
    - kubectl delete job db-migration -n $DYNAMIC_NAMESPACE --ignore-not-found
    - python3 scripts/deploy_stack.py
    - kubectl wait --for=condition=complete --timeout=600s job/db-migration -n $DYNAMIC_NAMESPACE || true

deploy-dynamic-stack:
  extends: .deploy-dynamic
  rules:
    - if: $REMOVE_DYNAMIC
      when: never
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
      when: never
    - if: $CI_PIPELINE_SOURCE == "pipeline"
    - if: $CI_PIPELINE_SOURCE == "parent_pipeline"
    - if: $CI_PIPELINE_SOURCE == "trigger"
    - if: $CI_PIPELINE_SOURCE == "web"

mr_pipeline_placeholder:
  stage: deploy
  image: alpine:latest
  tags:
%{ for tag in runner_tags ~}
    - ${tag}
%{ endfor ~}
  script:
    - echo "MR pipeline noop. Real deploys run downstream from service MRs."
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"

e2e_tests:
  stage: e2e-test
  trigger:
    project: example/e2e-tests
    branch: e2e-dynamic
    strategy: depend
  variables:
    E2E_DYNAMIC_STACK: "true"
    APP_BASE_URL: https://app-$DYNAMIC_ENV_HOST
    CUSTOM_WS_URL: wss://app-$DYNAMIC_ENV_HOST/ws
    DATABASE_URL: postgresql://postgres:postgres@postgres-postgresql.$DYNAMIC_NAMESPACE.svc.cluster.local:5432/postgres
  rules:
    - if: $REMOVE_DYNAMIC
      when: never
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
      when: never
    - if: $CI_PIPELINE_SOURCE == "pipeline"
    - if: $CI_PIPELINE_SOURCE == "parent_pipeline"
    - if: $CI_PIPELINE_SOURCE == "trigger"
    - if: $CI_PIPELINE_SOURCE == "web"

remove-dynamic-stack:
  stage: remove
  image:
    name: alpine/k8s:1.20.15
    entrypoint: ["/bin/sh", "-c"]
  tags:
%{ for tag in runner_tags ~}
    - ${tag}
%{ endfor ~}
  environment:
    name: review/$DYNAMIC_NAMESPACE
    action: stop
    kubernetes:
      agent: $GITLAB_AGENT_PATH
      dashboard:
        namespace: $DYNAMIC_NAMESPACE
  script:
    - python3 scripts/clean_stack.py --namespace $DYNAMIC_NAMESPACE
    - kubectl delete namespace "$DYNAMIC_NAMESPACE" --ignore-not-found=true
  rules:
    - if: $REMOVE_DYNAMIC
